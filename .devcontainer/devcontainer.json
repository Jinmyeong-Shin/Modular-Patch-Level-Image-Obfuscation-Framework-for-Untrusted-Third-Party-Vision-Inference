{
    "name": "Modular Patch-Level Image Obfuscation Framework",
    "image": "pytorch/pytorch:2.11.0-cuda13.0-cudnn9-runtime",
    "workspaceFolder": "/workspace",
    
    "features": {
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/node:1": { "version": "22" }
    },

    "runArgs": ["--runtime", "nvidia", "--gpus", "all"],

    "postCreateCommand": "python3 -m venv /workspace/.venv && /workspace/.venv/bin/pip install -r requirements.txt",
    "remoteEnv": {
      "PATH": "/workspace/.venv/bin:${containerEnv:PATH}",
      "VIRTUAL_ENV": "/workspace/.venv"
    },
    
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-python.debugpy",
                "ms-toolsai.jupyter",
                "ms-toolsai.jupyter-keymap",
                "ms-toolsai.jupyter-renderers",
                "ms-toolsai.vscode-jupyter-cell-tags",
                "ms-toolsai.vscode-jupyter-slideshow"
            ],
            "settings": {
                "terminal.integrated.automationProfile.linux": {
                    "path": "bash"
                },
                "python.defaultInterpreterPath": "/workspace/.venv/bin/python",
                "python.terminal.activateEnvironment": true,
                "jupyter.notebookFileRoot": "${workspaceFolder}"
            }
        }
    }
}
